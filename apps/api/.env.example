# ============================================================
# Enterprise POS System — API Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ---------------------------
# Application
# ---------------------------
NODE_ENV=development
PORT=4000
APP_NAME=Enterprise POS API

# ---------------------------
# Database (PostgreSQL)
# ---------------------------
DATABASE_URL=postgresql://pos_user:pos_password@localhost:5432/enterprise_pos

# ---------------------------
# Cache (Redis)
# ---------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------
# CORS
# ---------------------------
FRONTEND_URL=http://localhost:3000

# ---------------------------
# Security & JWT Tokens
# ---------------------------
# PRODUCTION: Secrets MUST be at least 32 characters (cryptographically secure)!
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_secure_random_string_of_at_least_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_me_to_another_secure_random_string_of_at_least_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d

# ---------------------------
# Email (SMTP)
# ---------------------------
# Optional: if not set, emails are logged to console only (dev mode)
# Supports: Gmail, SendGrid SMTP, AWS SES SMTP, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourcompany.com

# ---------------------------
# File Storage
# ---------------------------
# STORAGE_PROVIDER: local | s3 | r2 | minio
STORAGE_PROVIDER=local
# For S3/R2/MinIO (only required when STORAGE_PROVIDER is not 'local'):
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_BUCKET=enterprise-pos-uploads
# STORAGE_PUBLIC_URL=https://cdn.yourcompany.com
# STORAGE_ENDPOINT=https://s3.amazonaws.com  # Override for MinIO/R2
# STORAGE_FORCE_PATH_STYLE=false

# ---------------------------
# Prometheus Metrics
# ---------------------------
# Optional: protect /metrics endpoint in production
# METRICS_SECRET_KEY=change_me_to_a_secret_metrics_scrape_key