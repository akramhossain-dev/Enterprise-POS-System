# ============================================================
# Enterprise POS System — API Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ---------------------------
# Application
# ---------------------------
NODE_ENV=development
PORT=4000
APP_NAME=Enterprise POS API

# ---------------------------
# Database (PostgreSQL)
# ---------------------------
DATABASE_URL=postgresql://pos_user:pos_password@localhost:5432/enterprise_pos

# ---------------------------
# Cache (Redis)
# ---------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------
# CORS
# ---------------------------
FRONTEND_URL=http://localhost:3000

# ---------------------------
# Security & JWT Tokens
# ---------------------------
# Set strong secrets in production!
JWT_SECRET=super_secret_jwt_sign_key_change_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=super_secret_refresh_token_sign_key_change_in_production
REFRESH_TOKEN_EXPIRES_IN=7d