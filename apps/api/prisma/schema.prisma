// ─────────────────────────────────────────────
// Prisma Schema — Enterprise POS System
// ─────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Status {
  ACTIVE
  INACTIVE
  PENDING
  DELETED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  VIP
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum WarehouseStatus {
  ACTIVE
  INACTIVE
}

// ─────────────────────────────────────────────
// Models — System Foundation
// ─────────────────────────────────────────────

model SystemConfig {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("system_configs")
}

// ─────────────────────────────────────────────
// Models — Authentication & Users
// ─────────────────────────────────────────────

model User {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @db.VarChar(255)
  email         String         @unique @db.VarChar(255)
  password      String         @db.VarChar(255)
  phone         String?        @db.VarChar(50)
  status        Status         @default(ACTIVE)
  roleId        String         @map("role_id") @db.Uuid
  role          Role           @relation(fields: [roleId], references: [id], onDelete: Restrict)
  refreshTokens RefreshToken[]
  employee      Employee?
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique @db.VarChar(100)
  description     String?          @db.Text
  users           User[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique @db.VarChar(150)
  module          String           @db.VarChar(100)
  action          String           @db.VarChar(50)
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique @db.VarChar(255)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// Models — Business Domain
// ─────────────────────────────────────────────

model Company {
  id              String            @id @default(uuid()) @db.Uuid
  name            String            @db.VarChar(255)
  logoUrl         String?           @map("logo_url") @db.Text
  address         String?           @db.Text
  phone           String?           @db.VarChar(50)
  email           String?           @db.VarChar(255)
  taxNumber       String?           @map("tax_number") @db.VarChar(100)
  currency        String            @default("USD") @db.VarChar(10)
  fiscalYearStart DateTime?         @map("fiscal_year_start") @db.Date
  status          Status            @default(ACTIVE)
  branches        Branch[]
  employees       Employee[]
  settings        BusinessSetting[]
  // Catalog relations
  categories      Category[]
  brands          Brand[]
  units           Unit[]
  taxes           Tax[]
  products        Product[]
  // Customer relations
  customers       Customer[]
  // Supplier relations
  suppliers       Supplier[]
  // Warehouse relations
  warehouses      Warehouse[]
  // Stock operations (B7.2)
  stockMovements  StockMovement[]
  stockAdjustments StockAdjustment[]
  stockTransfers  StockTransfer[]
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  @@map("companies")
}

model Branch {
  id         String      @id @default(uuid()) @db.Uuid
  companyId  String      @map("company_id") @db.Uuid
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String      @db.VarChar(255)
  address    String?     @db.Text
  phone      String?     @db.VarChar(50)
  email      String?     @db.VarChar(255)
  status     Status      @default(ACTIVE)
  employees  Employee[]
  customers  Customer[]
  warehouses Warehouse[]
  // Stock operations (B7.2)
  stockMovements StockMovement[]
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  @@map("branches")
}

model Employee {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String?        @unique @map("user_id") @db.Uuid
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId String         @map("company_id") @db.Uuid
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId  String         @map("branch_id") @db.Uuid
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  firstName String         @map("first_name") @db.VarChar(100)
  lastName  String         @map("last_name") @db.VarChar(100)
  phone     String?        @db.VarChar(50)
  email     String?        @db.VarChar(255)
  hireDate  DateTime?      @map("hire_date") @db.Date
  status    EmployeeStatus @default(ACTIVE)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime?      @map("deleted_at") @db.Timestamptz

  @@map("employees")
}

model BusinessSetting {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  key       String   @db.VarChar(100)
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([companyId, key])
  @@map("business_settings")
}

// ─────────────────────────────────────────────
// Models — Product Catalog Domain
// ─────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String    @db.VarChar(255)
  description String?   @db.Text
  status      Status    @default(ACTIVE)
  products    Product[]
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([companyId])
  @@map("categories")
}

model Brand {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String    @db.VarChar(255)
  description String?   @db.Text
  status      Status    @default(ACTIVE)
  products    Product[]
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([companyId])
  @@map("brands")
}

model Unit {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String    @db.VarChar(100)
  shortName String    @map("short_name") @db.VarChar(20)
  status    Status    @default(ACTIVE)
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([companyId])
  @@map("units")
}

model Tax {
  id         String    @id @default(uuid()) @db.Uuid
  companyId  String    @map("company_id") @db.Uuid
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String    @db.VarChar(100)
  percentage Decimal   @db.Decimal(6, 4)
  status     Status    @default(ACTIVE)
  products   Product[]
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([companyId])
  @@map("taxes")
}

model Product {
  id            String         @id @default(uuid()) @db.Uuid
  companyId     String         @map("company_id") @db.Uuid
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId    String?        @map("category_id") @db.Uuid
  category      Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandId       String?        @map("brand_id") @db.Uuid
  brand         Brand?         @relation(fields: [brandId], references: [id], onDelete: SetNull)
  unitId        String         @map("unit_id") @db.Uuid
  unit          Unit           @relation(fields: [unitId], references: [id], onDelete: Restrict)
  taxId         String?        @map("tax_id") @db.Uuid
  tax           Tax?           @relation(fields: [taxId], references: [id], onDelete: SetNull)
  name          String         @db.VarChar(255)
  sku           String?        @unique @db.VarChar(100)
  barcode       String?        @unique @db.VarChar(100)
  description   String?        @db.Text
  purchasePrice Decimal        @map("purchase_price") @db.Decimal(12, 4)
  sellingPrice  Decimal        @map("selling_price") @db.Decimal(12, 4)
  image         String?        @db.Text
  status        ProductStatus  @default(ACTIVE)
  images        ProductImage[]
  inventories        Inventory[]
  // Stock operations (B7.2)
  stockMovements     StockMovement[]
  stockAdjustments   StockAdjustment[]
  stockTransferItems StockTransferItem[]
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  @@index([companyId])
  @@index([sku])
  @@index([barcode])
  @@index([name])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String   @db.Text
  altText   String?  @map("alt_text") @db.VarChar(255)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([productId])
  @@map("product_images")
}

// ─────────────────────────────────────────────
// Models — Customer Domain
// ─────────────────────────────────────────────

model Customer {
  id               String            @id @default(uuid()) @db.Uuid
  companyId        String            @map("company_id") @db.Uuid
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId         String?           @map("branch_id") @db.Uuid
  branch           Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customerCode     String            @unique @map("customer_code") @db.VarChar(20)
  firstName        String            @map("first_name") @db.VarChar(100)
  lastName         String            @map("last_name") @db.VarChar(100)
  fullName         String            @map("full_name") @db.VarChar(205)
  email            String?           @unique @db.VarChar(255)
  phone            String?           @unique @db.VarChar(50)
  alternativePhone String?           @map("alternative_phone") @db.VarChar(50)
  dateOfBirth      DateTime?         @map("date_of_birth") @db.Date
  gender           Gender?
  nationalId       String?           @map("national_id") @db.VarChar(100)
  taxNumber        String?           @map("tax_number") @db.VarChar(100)
  creditLimit      Decimal           @default(0) @map("credit_limit") @db.Decimal(15, 4)
  openingBalance   Decimal           @default(0) @map("opening_balance") @db.Decimal(15, 4)
  currentBalance   Decimal           @default(0) @map("current_balance") @db.Decimal(15, 4)
  loyaltyPoints    Int               @default(0) @map("loyalty_points")
  status           CustomerStatus    @default(ACTIVE)
  notes            String?           @db.Text
  addresses        CustomerAddress[]
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz

  @@index([customerCode])
  @@index([phone])
  @@index([email])
  @@index([fullName])
  @@index([companyId])
  @@index([branchId])
  @@map("customers")
}

model CustomerAddress {
  id           String   @id @default(uuid()) @db.Uuid
  customerId   String   @map("customer_id") @db.Uuid
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label        String   @db.VarChar(100)
  country      String?  @db.VarChar(100)
  state        String?  @db.VarChar(100)
  city         String?  @db.VarChar(100)
  area         String?  @db.VarChar(100)
  postalCode   String?  @map("postal_code") @db.VarChar(20)
  addressLine1 String   @map("address_line1") @db.VarChar(255)
  addressLine2 String?  @map("address_line2") @db.VarChar(255)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([customerId])
  @@map("customer_addresses")
}

// ─────────────────────────────────────────────
// Models — Supplier Domain
// ─────────────────────────────────────────────

model Supplier {
  id               String            @id @default(uuid()) @db.Uuid
  companyId        String            @map("company_id") @db.Uuid
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierCode     String            @unique @map("supplier_code") @db.VarChar(20)
  companyName      String            @map("company_name") @db.VarChar(255)
  contactPerson    String?           @map("contact_person") @db.VarChar(200)
  email            String?           @unique @db.VarChar(255)
  phone            String?           @unique @db.VarChar(50)
  alternativePhone String?           @map("alternative_phone") @db.VarChar(50)
  website          String?           @db.VarChar(255)
  taxNumber        String?           @map("tax_number") @db.VarChar(100)
  creditLimit      Decimal           @default(0) @map("credit_limit") @db.Decimal(15, 4)
  openingBalance   Decimal           @default(0) @map("opening_balance") @db.Decimal(15, 4)
  currentBalance   Decimal           @default(0) @map("current_balance") @db.Decimal(15, 4)
  status           SupplierStatus    @default(ACTIVE)
  notes            String?           @db.Text
  addresses        SupplierAddress[]
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz

  @@index([supplierCode])
  @@index([companyName])
  @@index([phone])
  @@index([email])
  @@index([companyId])
  @@map("suppliers")
}

model SupplierAddress {
  id           String   @id @default(uuid()) @db.Uuid
  supplierId   String   @map("supplier_id") @db.Uuid
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  label        String   @db.VarChar(100)
  country      String?  @db.VarChar(100)
  state        String?  @db.VarChar(100)
  city         String?  @db.VarChar(100)
  area         String?  @db.VarChar(100)
  postalCode   String?  @map("postal_code") @db.VarChar(20)
  addressLine1 String   @map("address_line1") @db.VarChar(255)
  addressLine2 String?  @map("address_line2") @db.VarChar(255)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([supplierId])
  @@map("supplier_addresses")
}

// ─────────────────────────────────────────────
// Models — Warehouse & Inventory Domain
// ─────────────────────────────────────────────

model Warehouse {
  id          String          @id @default(uuid()) @db.Uuid
  companyId   String          @map("company_id") @db.Uuid
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId    String?         @map("branch_id") @db.Uuid
  branch      Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  code        String          @unique @db.VarChar(20)
  name        String          @db.VarChar(255)
  phone       String?         @db.VarChar(50)
  email       String?         @db.VarChar(255)
  managerName String?         @map("manager_name") @db.VarChar(200)
  country     String?         @db.VarChar(100)
  city        String?         @db.VarChar(100)
  address     String?         @db.Text
  status      WarehouseStatus @default(ACTIVE)
  isDefault   Boolean         @default(false) @map("is_default")
  inventories Inventory[]
  // Stock operations (B7.2)
  stockMovements   StockMovement[]
  stockAdjustments StockAdjustment[]
  transfersFrom    StockTransfer[]  @relation("TransferFrom")
  transfersTo      StockTransfer[]  @relation("TransferTo")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?       @map("deleted_at") @db.Timestamptz

  @@index([code])
  @@index([name])
  @@index([companyId])
  @@index([branchId])
  @@map("warehouses")
}

model Inventory {
  id                String    @id @default(uuid()) @db.Uuid
  companyId         String    @map("company_id") @db.Uuid
  warehouseId       String    @map("warehouse_id") @db.Uuid
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId         String    @map("product_id") @db.Uuid
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  availableQuantity Decimal   @default(0) @map("available_quantity") @db.Decimal(15, 4)
  reservedQuantity  Decimal   @default(0) @map("reserved_quantity") @db.Decimal(15, 4)
  damagedQuantity   Decimal   @default(0) @map("damaged_quantity") @db.Decimal(15, 4)
  minimumQuantity   Decimal   @default(0) @map("minimum_quantity") @db.Decimal(15, 4)
  reorderQuantity   Decimal   @default(0) @map("reorder_quantity") @db.Decimal(15, 4)
  maximumQuantity   Decimal?  @map("maximum_quantity") @db.Decimal(15, 4)
  averageCost       Decimal   @default(0) @map("average_cost") @db.Decimal(15, 4)
  lastPurchasePrice Decimal   @default(0) @map("last_purchase_price") @db.Decimal(15, 4)
  hasOpeningStock   Boolean   @default(false) @map("has_opening_stock")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([warehouseId, productId])
  @@index([companyId])
  @@index([warehouseId])
  @@index([productId])
  @@map("inventories")
}

// ─────────────────────────────────────────────
// Enums — Stock Operations (B7.2)
// ─────────────────────────────────────────────

enum MovementType {
  OPENING_STOCK
  PURCHASE
  PURCHASE_RETURN
  SALE
  SALE_RETURN
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  DAMAGE
  EXPIRED
  LOST
  MANUAL
}

enum AdjustmentType {
  INCREASE
  DECREASE
  DAMAGE
  EXPIRED
  LOST
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

// ─────────────────────────────────────────────
// Models — Stock Operations (B7.2)
// ─────────────────────────────────────────────

model StockMovement {
  id               String       @id @default(uuid()) @db.Uuid
  companyId        String       @map("company_id") @db.Uuid
  company          Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId         String?      @map("branch_id") @db.Uuid
  branch           Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  warehouseId      String       @map("warehouse_id") @db.Uuid
  warehouse        Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId        String       @map("product_id") @db.Uuid
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  referenceType    String?      @map("reference_type") @db.VarChar(50)
  referenceId      String?      @map("reference_id") @db.Uuid
  movementType     MovementType @map("movement_type")
  quantity         Decimal      @db.Decimal(15, 4)
  previousQuantity Decimal      @map("previous_quantity") @db.Decimal(15, 4)
  newQuantity      Decimal      @map("new_quantity") @db.Decimal(15, 4)
  unitCost         Decimal?     @map("unit_cost") @db.Decimal(15, 4)
  remarks          String?      @db.Text
  performedBy      String       @map("performed_by") @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@index([companyId])
  @@index([warehouseId])
  @@index([productId])
  @@index([movementType])
  @@index([referenceType, referenceId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("stock_movements")
}

model StockAdjustment {
  id          String         @id @default(uuid()) @db.Uuid
  companyId   String         @map("company_id") @db.Uuid
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId String         @map("warehouse_id") @db.Uuid
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId   String         @map("product_id") @db.Uuid
  product     Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        AdjustmentType
  quantity    Decimal        @db.Decimal(15, 4)
  reason      String         @db.VarChar(500)
  remarks     String?        @db.Text
  approvedBy  String?        @map("approved_by") @db.Uuid
  createdBy   String         @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz

  @@index([companyId])
  @@index([warehouseId])
  @@index([productId])
  @@index([type])
  @@index([createdBy])
  @@index([createdAt])
  @@map("stock_adjustments")
}

model StockTransfer {
  id              String         @id @default(uuid()) @db.Uuid
  companyId       String         @map("company_id") @db.Uuid
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromWarehouseId String         @map("from_warehouse_id") @db.Uuid
  fromWarehouse   Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id], onDelete: Cascade)
  toWarehouseId   String         @map("to_warehouse_id") @db.Uuid
  toWarehouse     Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id], onDelete: Cascade)
  status          TransferStatus @default(PENDING)
  remarks         String?        @db.Text
  createdBy       String         @map("created_by") @db.Uuid
  approvedBy      String?        @map("approved_by") @db.Uuid
  items           StockTransferItem[]
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  @@index([companyId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
  @@index([createdBy])
  @@map("stock_transfers")
}

model StockTransferItem {
  id         String        @id @default(uuid()) @db.Uuid
  transferId String        @map("transfer_id") @db.Uuid
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String        @map("product_id") @db.Uuid
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity   Decimal       @db.Decimal(15, 4)

  @@unique([transferId, productId])
  @@index([transferId])
  @@index([productId])
  @@map("stock_transfer_items")
}
