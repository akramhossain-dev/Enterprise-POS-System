  supplier       Supplier                @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  entryType      SupplierLedgerEntryType @map("entry_type")
  amount         Decimal                 @db.Decimal(15, 4)
  runningBalance Decimal                 @map("running_balance") @db.Decimal(15, 4)
  referenceId    String                  @map("reference_id") @db.Uuid
  referenceNo    String                  @map("reference_no") @db.VarChar(100)
  description    String?                 @db.Text
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz

  @@index([companyId])
  @@index([supplierId])
  @@index([createdAt])
  @@map("supplier_ledger_entries")
}

enum POSSessionStatus {
  OPEN
  CLOSED
  SUSPENDED
}

model POSSession {
  id            String           @id @default(uuid()) @db.Uuid
  companyId     String           @map("company_id") @db.Uuid
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId      String?          @map("branch_id") @db.Uuid
  branch        Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  warehouseId   String           @map("warehouse_id") @db.Uuid
  warehouse     Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  cashierId     String           @map("cashier_id") @db.Uuid
  cashier       User             @relation(fields: [cashierId], references: [id], onDelete: Cascade)
  sessionNumber String           @map("session_number") @db.VarChar(100)
  openingCash   Decimal          @map("opening_cash") @db.Decimal(15, 4)
  closingCash   Decimal?         @map("closing_cash") @db.Decimal(15, 4)
  status        POSSessionStatus @default(OPEN)
  openedAt      DateTime         @default(now()) @map("opened_at") @db.Timestamptz
  closedAt      DateTime?        @map("closed_at") @db.Timestamptz
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz
  carts         Cart[]
  sales         Sale[]

  @@unique([companyId, sessionNumber])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([cashierId])
  @@map("pos_sessions")
}

enum CartStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  HOLD
}

model Cart {
  id         String     @id @default(uuid()) @db.Uuid
  sessionId  String     @map("session_id") @db.Uuid
  session    POSSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  customerId String?    @map("customer_id") @db.Uuid
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status     CartStatus @default(ACTIVE)
  subtotal   Decimal    @db.Decimal(15, 4)
  discount   Decimal    @default(0) @db.Decimal(15, 4)
  tax        Decimal    @default(0) @db.Decimal(15, 4)
  grandTotal Decimal    @map("grand_total") @db.Decimal(15, 4)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  items      CartItem[]

  @@index([sessionId])
  @@index([customerId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Decimal  @db.Decimal(15, 4)
  unitPrice Decimal  @map("unit_price") @db.Decimal(15, 4)
  discount  Decimal  @default(0) @db.Decimal(15, 4)
  tax       Decimal  @default(0) @db.Decimal(15, 4)
  total     Decimal  @db.Decimal(15, 4)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────
// Point of Sale — Checkout, Payment & Invoice (B9.2)
// ─────────────────────────────────────────────

enum SaleStatus {
  COMPLETED
  CANCELLED
  PENDING
}

enum PaymentStatus {
  PAID
  PARTIAL
  DUE
}

model Sale {
  id            String        @id @default(uuid()) @db.Uuid
  companyId     String        @map("company_id") @db.Uuid
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId      String?       @map("branch_id") @db.Uuid
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  warehouseId   String        @map("warehouse_id") @db.Uuid
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  customerId    String?       @map("customer_id") @db.Uuid
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  sessionId     String        @map("session_id") @db.Uuid
  session       POSSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  invoiceNumber String        @map("invoice_number") @db.VarChar(100)
  saleDate      DateTime      @default(now()) @map("sale_date") @db.Timestamptz
  subtotal      Decimal       @db.Decimal(15, 4)
  discount      Decimal       @default(0) @db.Decimal(15, 4)
  tax           Decimal       @default(0) @db.Decimal(15, 4)
  grandTotal    Decimal       @map("grand_total") @db.Decimal(15, 4)
  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal(15, 4)
  dueAmount     Decimal       @default(0) @map("due_amount") @db.Decimal(15, 4)
  paymentStatus PaymentStatus @default(DUE) @map("payment_status")
  status        SaleStatus    @default(PENDING)
  createdBy     String        @map("created_by") @db.Uuid
  creator       User          @relation("SaleCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  items         SaleItem[]
  payments      Payment[]
  invoice       Invoice?
  returns       SalesReturn[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([customerId])
  @@index([sessionId])
  @@index([paymentStatus])
  @@index([status])
  @@map("sales")
}

model SaleItem {
  id        String   @id @default(uuid()) @db.Uuid
  saleId    String   @map("sale_id") @db.Uuid
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Decimal  @db.Decimal(15, 4)
  unitPrice Decimal  @map("unit_price") @db.Decimal(15, 4)
  discount  Decimal  @default(0) @db.Decimal(15, 4)
  tax       Decimal  @default(0) @db.Decimal(15, 4)
  total     Decimal  @db.Decimal(15, 4)
  returnItems SalesReturnItem[]

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  saleId        String        @map("sale_id") @db.Uuid
  sale          Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod @map("payment_method")
  amount        Decimal       @db.Decimal(15, 4)
  reference     String?       @db.VarChar(255)
  transactionId String?       @map("transaction_id") @db.VarChar(255)
  paidAt        DateTime      @default(now()) @map("paid_at") @db.Timestamptz
  createdBy     String        @map("created_by") @db.Uuid
  creator       User          @relation("PaymentCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("payments")
}

model Invoice {
  id            String   @id @default(uuid()) @db.Uuid
  saleId        String   @unique @map("sale_id") @db.Uuid
  sale          Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  invoiceNumber String   @map("invoice_number") @db.VarChar(100)
  invoiceDate   DateTime @default(now()) @map("invoice_date") @db.Timestamptz
  printCount    Int      @default(0) @map("print_count")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([saleId, invoiceNumber])
  @@index([invoiceNumber])
  @@map("invoices")
}

// ─────────────────────────────────────────────
// Point of Sale — Sales Return, Refund & Customer Due (B9.3)
// ─────────────────────────────────────────────

enum SalesReturnStatus {
  DRAFT
  APPROVED
  COMPLETED
  CANCELLED
}

enum RefundMethod {
  CASH
  BANK
  CARD
  MOBILE_BANKING
  STORE_CREDIT
}

enum CustomerLedgerEntryType {
  SALE
  PAYMENT
  RETURN
  ADJUSTMENT
}

model SalesReturn {
  id           String            @id @default(uuid()) @db.Uuid
  companyId    String            @map("company_id") @db.Uuid
  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId     String?           @map("branch_id") @db.Uuid
  branch       Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  warehouseId  String            @map("warehouse_id") @db.Uuid
  warehouse    Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  customerId   String?           @map("customer_id") @db.Uuid
  customer     Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  saleId       String            @map("sale_id") @db.Uuid
  sale         Sale              @relation(fields: [saleId], references: [id], onDelete: Cascade)
  returnNumber String            @map("return_number") @db.VarChar(100)
  returnDate   DateTime          @default(now()) @map("return_date") @db.Timestamptz
  status       SalesReturnStatus @default(DRAFT)
  subtotal     Decimal           @db.Decimal(15, 4)
  tax          Decimal           @default(0) @db.Decimal(15, 4)
  discount     Decimal           @default(0) @db.Decimal(15, 4)
  grandTotal   Decimal           @map("grand_total") @db.Decimal(15, 4)
  refundAmount Decimal           @default(0) @map("refund_amount") @db.Decimal(15, 4)
  reason       String?           @db.Text
  createdBy    String            @map("created_by") @db.Uuid
  creator      User              @relation("SalesReturnCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  items        SalesReturnItem[]
  refunds      Refund[]

  @@unique([companyId, returnNumber])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([customerId])
  @@index([saleId])
  @@index([status])
  @@map("sales_returns")
}

model SalesReturnItem {
  id            String      @id @default(uuid()) @db.Uuid
  salesReturnId String      @map("sales_return_id") @db.Uuid
  salesReturn   SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  saleItemId    String      @map("sale_item_id") @db.Uuid
  saleItem      SaleItem    @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  productId     String      @map("product_id") @db.Uuid
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity      Decimal     @db.Decimal(15, 4)
  unitPrice     Decimal     @map("unit_price") @db.Decimal(15, 4)
  total         Decimal     @db.Decimal(15, 4)

  @@index([salesReturnId])
  @@index([productId])
  @@map("sales_return_items")
}

model Refund {
  id            String       @id @default(uuid()) @db.Uuid
  salesReturnId String?      @map("sales_return_id") @db.Uuid
  salesReturn   SalesReturn? @relation(fields: [salesReturnId], references: [id], onDelete: SetNull)
  customerId    String       @map("customer_id") @db.Uuid
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount        Decimal      @db.Decimal(15, 4)
  refundMethod  RefundMethod @map("refund_method")
  reference     String?      @db.VarChar(255)
  createdBy     String       @map("created_by") @db.Uuid
  creator       User         @relation("RefundCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@index([salesReturnId])
  @@index([customerId])
  @@map("refunds")
}

model CustomerLedgerEntry {
  id             String                  @id @default(uuid()) @db.Uuid
  companyId      String                  @map("company_id") @db.Uuid
  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId     String                  @map("customer_id") @db.Uuid
  customer       Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  entryType      CustomerLedgerEntryType @map("entry_type")
  amount         Decimal                 @db.Decimal(15, 4)
  runningBalance Decimal                 @map("running_balance") @db.Decimal(15, 4)
  referenceId    String                  @map("reference_id") @db.Uuid
  referenceNo    String                  @map("reference_no") @db.VarChar(100)
  description    String?                 @db.Text
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz

  @@index([companyId])
  @@index([customerId])
  @@index([createdAt])
  @@map("customer_ledger_entries")
}

// ─────────────────────────────────────────────
// Accounting Foundation (B10.1)
// ─────────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

model AccountCategory {
  id        String      @id @default(uuid()) @db.Uuid
  companyId String      @map("company_id") @db.Uuid
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String      @db.VarChar(100)
  type      AccountType
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz

  accounts  Account[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("account_categories")
}

model Account {
  id             String        @id @default(uuid()) @db.Uuid
  companyId      String        @map("company_id") @db.Uuid
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId     String        @map("category_id") @db.Uuid
  category       AccountCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  parentId       String?       @map("parent_id") @db.Uuid
  parent         Account?      @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  accountCode    String        @map("account_code") @db.VarChar(100)
  name           String        @db.VarChar(150)
  type           AccountType
  openingBalance Decimal       @default(0) @map("opening_balance") @db.Decimal(15, 4)
  currentBalance Decimal       @default(0) @map("current_balance") @db.Decimal(15, 4)
  status         AccountStatus @default(ACTIVE)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  children       Account[]     @relation("AccountHierarchy")
  journalItems   JournalEntryItem[]
  expenses       Expense[]
  incomes        Income[]
  paymentReceipts PaymentReceipt[]
  paymentVouchers PaymentVoucher[]

  @@unique([companyId, accountCode])
  @@index([companyId])
  @@index([categoryId])
  @@index([parentId])
  @@map("accounts")
}

model JournalEntry {
  id            String             @id @default(uuid()) @db.Uuid
  companyId     String             @map("company_id") @db.Uuid
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  referenceType String?            @map("reference_type") @db.VarChar(100)
  referenceId   String?            @map("reference_id") @db.Uuid
  entryNumber   String             @map("entry_number") @db.VarChar(100)
  date          DateTime           @map("date") @db.Timestamptz
  description   String?            @db.Text
  createdBy     String             @map("created_by") @db.Uuid
  creator       User               @relation("JournalCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz

  items         JournalEntryItem[]

  @@unique([companyId, entryNumber])
  @@index([companyId])
  @@index([date])
  @@map("journal_entries")
}

model JournalEntryItem {
  id             String       @id @default(uuid()) @db.Uuid
  journalEntryId String       @map("journal_entry_id") @db.Uuid
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String       @map("account_id") @db.Uuid
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  debit          Decimal      @db.Decimal(15, 4)
  credit         Decimal      @db.Decimal(15, 4)

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_items")
}

enum ExpenseCategoryStatus {
  ACTIVE
  INACTIVE
}

enum ExpenseStatus {
  ACTIVE
  CANCELLED
}

enum IncomeStatus {
  ACTIVE
  CANCELLED
}


model ExpenseCategory {
  id          String                @id @default(uuid()) @db.Uuid
  companyId   String                @map("company_id") @db.Uuid
  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String                @db.VarChar(100)
  description String?               @db.Text
  status      ExpenseCategoryStatus @default(ACTIVE)
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  expenses    Expense[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("expense_categories")
}

model Expense {
  id            String          @id @default(uuid()) @db.Uuid
  companyId     String          @map("company_id") @db.Uuid
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId      String?         @map("branch_id") @db.Uuid
  branch        Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  categoryId    String          @map("category_id") @db.Uuid
  category      ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  accountId     String          @map("account_id") @db.Uuid
  account       Account         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  expenseNumber String          @map("expense_number") @db.VarChar(100)
  date          DateTime        @db.Timestamptz
  amount        Decimal         @db.Decimal(15, 4)
  paymentMethod PaymentMethod   @map("payment_method")
  reference     String?         @db.VarChar(100)
  description   String?         @db.Text
  attachment    String?         @db.Text
  status        ExpenseStatus   @default(ACTIVE)
  createdBy     String          @map("created_by") @db.Uuid
  creator       User            @relation("ExpenseCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([companyId, expenseNumber])
  @@index([companyId])
  @@index([branchId])
  @@index([categoryId])
  @@index([accountId])
  @@map("expenses")
}

model Income {
  id            String        @id @default(uuid()) @db.Uuid
  companyId     String        @map("company_id") @db.Uuid
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId      String?       @map("branch_id") @db.Uuid
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  accountId     String        @map("account_id") @db.Uuid
  account       Account       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  incomeNumber  String        @map("income_number") @db.VarChar(100)
  date          DateTime      @db.Timestamptz
  amount        Decimal       @db.Decimal(15, 4)
  source        String?       @db.VarChar(150)
  paymentMethod PaymentMethod @map("payment_method")
  reference     String?       @db.VarChar(100)
  description   String?       @db.Text
  status        IncomeStatus  @default(ACTIVE)
  createdBy     String        @map("created_by") @db.Uuid
  creator       User          @relation("IncomeCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([companyId, incomeNumber])
  @@index([companyId])
  @@index([branchId])
  @@index([accountId])
  @@map("incomes")
}

enum ReceiptType {
  CUSTOMER_PAYMENT
  SUPPLIER_PAYMENT
  ADVANCE_RECEIVE
  ADVANCE_PAYMENT
  OTHER
}

enum VoucherType {
  RECEIPT
  PAYMENT
  CONTRA
  JOURNAL
}

model PaymentReceipt {
  id            String         @id @default(uuid()) @db.Uuid
  companyId     String         @map("company_id") @db.Uuid
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId    String?        @map("customer_id") @db.Uuid
  customer      Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplierId    String?        @map("supplier_id") @db.Uuid
  supplier      Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  accountId     String         @map("account_id") @db.Uuid
  account       Account        @relation(fields: [accountId], references: [id], onDelete: Restrict)
  receiptNumber String         @map("receipt_number") @db.VarChar(100)
  type          ReceiptType
  amount        Decimal        @db.Decimal(15, 4)
  paymentMethod PaymentMethod  @map("payment_method")
  reference     String?        @db.VarChar(100)
  description   String?        @db.Text
  date          DateTime       @db.Timestamptz
  createdBy     String         @map("created_by") @db.Uuid
  creator       User           @relation("ReceiptCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz

  @@unique([companyId, receiptNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([supplierId])
  @@index([accountId])
  @@map("payment_receipts")
}

model PaymentVoucher {
  id            String         @id @default(uuid()) @db.Uuid
  companyId     String         @map("company_id") @db.Uuid
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  voucherNumber String         @map("voucher_number") @db.VarChar(100)
  type          VoucherType
  accountId     String         @map("account_id") @db.Uuid
  account       Account        @relation(fields: [accountId], references: [id], onDelete: Restrict)
  amount        Decimal        @db.Decimal(15, 4)
  paymentMethod PaymentMethod  @default(CASH) @map("payment_method")
  description   String?        @db.Text
  date          DateTime       @db.Timestamptz
  createdBy     String         @map("created_by") @db.Uuid
  creator       User           @relation("VoucherCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz

  @@unique([companyId, voucherNumber])
  @@index([companyId])
  @@index([accountId])
  @@map("payment_vouchers")
}
