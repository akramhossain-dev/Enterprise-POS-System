// ─────────────────────────────────────────────
// Prisma Schema — Enterprise POS System
// ─────────────────────────────────────────────
// Phase B1: Foundation setup only.
// No models are defined in this phase.
// Models will be added in Phase B2 (Authentication)
// and subsequent phases.
// ─────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

